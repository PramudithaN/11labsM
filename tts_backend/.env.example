# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Translation (pick one)
TRANSLATION_PROVIDER=deepl              # "deepl" or "google"
DEEPL_API_KEY=your_deepl_api_key_here
GOOGLE_TRANSLATE_API_KEY=your_google_key_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tts_db

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO storage
S3_ENDPOINT_URL=http://localhost:9000   # leave blank for real AWS S3
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tts-audio
S3_REGION=us-east-1

# App
APP_ENV=development
SECRET_KEY=change_me_to_a_long_random_string
MAX_TEXT_LENGTH=5000
MAX_LANGUAGES_PER_JOB=20
